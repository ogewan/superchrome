{
  "manifest_version": 3,
  "name": "SuperChrome",
  "version": "1.0",
  "description": "A powerful tab and browser management tool",
  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "system.memory",
    "processes"
  ],
  "action": {},
  "background": {
    "service_worker": "background.js"
  }
}
